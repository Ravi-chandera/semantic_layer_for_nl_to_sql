# Required for live chat, benchmark suite runs, chart planning, and semantic-layer regeneration.
GEMINI_API_KEY=

# Optional Langfuse tracing. Leave blank to run without tracing.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional semantic-cache embedding controls.
# Default behavior is async embedding backfill after cache writes.
NL_TO_SQL_CACHE_EMBEDDINGS=async
NL_TO_SQL_CACHE_EMBEDDING_DELAY_SECONDS=1
