  "join_paths": {
    "invoice_to_vendor": {
      "description": "Retrieve vendor details for a specific bill.",
      "use_when": "Who is the supplier for invoice INV-001?",
      "steps": [
        {
          "from": "invoices",
          "to": "vendors",
          "on": "invoices.vendor_id = vendors.id"
        }
      ]
    },
    "payment_to_vendor": {
      "description": "Find which supplier received a specific payment.",
      "use_when": "Which vendor did we pay 50,000 to last week?",
      "steps": [
        {
          "from": "payments",
          "to": "invoices",
          "on": "payments.invoice_id = invoices.id"
        },
        {
          "from": "invoices",
          "to": "vendors",
          "on": "invoices.vendor_id = vendors.id"
        }
      ]
    },
    "po_to_department": {
      "description": "Check which department requested an order.",
      "use_when": "Which department ordered the Cloud Hosting service?",
      "steps": [
        {
          "from": "purchase_orders",
          "to": "departments",
          "on": "purchase_orders.department_id = departments.id"
        }
      ]
    },
    "receipt_to_order": {
      "description": "Link receiving documents back to the purchase agreement.",
      "use_when": "Show me all GRNs related to PO-2025-0001.",
      "steps": [
        {
          "from": "grns",
          "to": "purchase_orders",
          "on": "grns.po_id = purchase_orders.id"
        }
      ]
    }
  },
  "metrics": {
    "total_spend": {
      "description": "Total amount paid to all vendors.",
      "sql": "SUM(amount)",
      "filters": null,
      "synonyms": ["total payments", "cash outflow"],
      "result_unit": "INR"
    },
    "total_liability": {
      "description": "Total amount of all unpaid or pending invoices.",
      "sql": "SUM(grand_total)",
      "filters": "status != 'paid'",
      "synonyms": ["outstanding balance", "accounts payable"],
      "result_unit": "INR"
    },
    "average_invoice_value": {
      "description": "The mean total of vendor bills.",
      "sql": "AVG(grand_total)",
      "filters": null,
      "synonyms": ["mean bill size"],
      "result_unit": "INR"
    },
    "rejection_rate": {
      "description": "Percentage of received goods that were rejected.",
      "sql": "SUM(quantity_rejected) * 100.0 / NULLIF(SUM(quantity_received + quantity_rejected), 0)",
      "filters": null,
      "synonyms": ["defect rate", "return percentage"],
      "result_unit": "percentage"
    },
    "order_fulfillment_count": {
      "description": "Number of closed purchase orders.",
      "sql": "COUNT(id)",
      "filters": "status = 'closed'",
      "synonyms": ["completed orders"],
      "result_unit": "count"
    }
  },
  "synonyms": {
    "entity_synonyms": {
      "vendors": ["suppliers", "providers", "partners"],
      "invoices": ["bills", "vouchers", "payables"],
      "purchase_orders": ["po", "orders", "procurement"],
      "payments": ["settlements", "payouts"],
      "grns": ["receipts", "deliveries"]
    },
    "status_synonyms": {
      "overdue": "due_date < date('now') AND status != 'paid'",
      "pending approval": "status = 'validated' AND approved_by IS NULL",
      "disputed": "deviation_type IS NOT NULL",
      "urgent": "due_date <= date('now', '+3 days') AND status != 'paid'"
    },
    "temporal_expressions": {
      "this_month": {
        "description": "Transactions in the current calendar month",
        "sql_template": "strftime('%Y-%m', {col}) = strftime('%Y-%m', 'now')",
        "example": "invoices from this month"
      },
      "last_month": {
        "description": "Transactions in the previous calendar month",
        "sql_template": "strftime('%Y-%m', {col}) = strftime('%Y-%m', 'now', '-1 month')",
        "example": "spend last month"
      },
      "ytd": {
        "description": "Year to date transactions",
        "sql_template": "strftime('%Y', {col}) = strftime('%Y', 'now') AND {col} <= date('now')",
        "example": "total spend ytd"
      },
      "last_30_days": {
        "description": "Transactions in the last 30 days",
        "sql_template": "{col} >= date('now', '-30 days')",
        "example": "orders in the last 30 days"
      }
    }
  },
  "ambiguity_rules": {
    "date_ambiguity": {
      "trigger_phrases": ["date", "when"],
      "ambiguous_dimensions": [
        {
          "label": "invoice_date",
          "sql_hint": "invoices.invoice_date"
        },
        {
          "label": "due_date",
          "sql_hint": "invoices.due_date"
        },
        {
          "label": "payment_date",
          "sql_hint": "payments.payment_date"
        }
      ],
      "clarification_question": "Are you referring to the date the bill was issued, the date it is due, or the date it was paid?",
      "default_assumption": "invoice_date"
    },
    "amount_ambiguity": {
      "trigger_phrases": ["amount", "value", "total"],
      "ambiguous_dimensions": [
        {
          "label": "grand_total",
          "sql_hint": "invoices.grand_total"
        },
        {
          "label": "taxable_amount",
          "sql_hint": "invoices.total_taxable_amount"
        },
        {
          "label": "payment_amount",
          "sql_hint": "payments.amount"
        }
      ],
      "clarification_question": "Do you mean the total billed amount (including tax), the taxable subtotal, or the actual amount paid?",
      "default_assumption": "grand_total"
    }
  },
  "query_hints": {
    "window_functions": [
      {
        "name": "vendor_spend_ranking",
        "description": "Rank vendors by total spend amount.",
        "trigger_phrases": ["top vendors", "highest spend", "rank suppliers"],
        "template": "SELECT vendor_id, SUM(grand_total) as total, RANK() OVER (ORDER BY SUM(grand_total) DESC) as spend_rank FROM invoices GROUP BY vendor_id"
      },
      {
        "name": "running_payment_total",
        "description": "Calculate cumulative spend over time.",
        "trigger_phrases": ["cumulative spend", "running total"],
        "template": "SELECT payment_date, amount, SUM(amount) OVER (ORDER BY payment_date) as running_total FROM payments"
      }
    ],
    "common_patterns": [
      {
        "name": "three_way_match",
        "description": "Reconcile PO, GRN, and Invoice quantities.",
        "trigger_phrases": ["3 way match", "reconcile", "mismatch"],
        "template": "SELECT po.po_number, pol.quantity as ordered, grnl.quantity_received as received, invl.quantity as billed FROM purchase_orders po JOIN po_line_items pol ON po.id = pol.po_id LEFT JOIN grn_line_items grnl ON pol.id = grnl.po_line_item_id LEFT JOIN invoice_line_items invl ON pol.product_id = invl.product_id"
      },
      {
        "name": "budget_utilization",
        "description": "Compare actual spend against department budget.",
        "trigger_phrases": ["budget check", "over budget"],
        "template": "SELECT d.name, d.budget_annual, SUM(i.grand_total) as actual_spend FROM departments d JOIN purchase_orders po ON d.id = po.department_id JOIN invoices i ON po.id = i.po_id GROUP BY d.id"
      }
    ]
  }
}